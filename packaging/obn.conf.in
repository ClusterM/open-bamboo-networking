# Open Bamboo Networking -- user settings
#
# Log settings can also be set via OBN_LOG_* environment variables;
# when set, they take priority over this file.

# --- Logging --------------------------------------------------------

log_level = info
log_stderr = 1
log_to_file = 0
log_file =


# --- BambuSource logging --------------------------------------------
#
# Logging for the BambuSource library (camera liveview / file browser).
# Same pattern as the main plugin: stderr by default, file on demand.
# Env vars (OBN_BAMBUSOURCE_LOG_*) override these when set.

bambusource_log_level = info
bambusource_log_stderr = 1
bambusource_log_to_file = 0
bambusource_log_file =

# --- LAN TLS --------------------------------------------------------
#
# Skip TLS certificate verification for LAN MQTT/FTPS connections.

lan_tls_skip_verify = 0

# --- Print behavior -------------------------------------------------
#
# Always save timelapse to external storage (USB/SD), ignoring the
# Internal/External toggle in the print dialog.  Studio defaults
# that toggle to internal storage, so this avoids switching it every time.

force_timelapse_external = 0

# --- File transfer --------------------------------------------------
#
# Force FTPS (port 990) for file listing and transfer instead of the
# native TLS :6000 CTRL protocol.  Thumbnails, timelapse files, and
# internal storage (eMMC) browsing are not available in this mode.
# Useful as a workaround when the printer's :6000 file browser is
# broken (e.g. some A1 firmware versions).

force_ftps = 0

# --- Device panel camera preview ------------------------------------
#
# When live view is off, Studio polls a static JPEG snapshot from the
# printer RAM (FILE_DOWNLOAD mem:/N over TLS :6000) and shows it in the
# large camera area ("Printer Preview …" overlay). Disable if that stale
# snapshot annoys you — it often shows an outdated picture that does not
# match what is actually printing.

disable_camera_preview = 0

# --- MQTT connection persistence -------------------------------------
#
# Keep the MQTT connection alive across the slicer's internal
# disconnect/reconnect cycles (e.g. after sending a print job).
# Useful for Orca Slicer, which reconnects to the printer after
# every print, causing a 5-30s delay on printers with limited
# MQTT session slots (A1 Mini, P1S, etc.).

mqtt_keep_connection = 1

# --- MQTT push_status patches ---------------------------------------
#
# Replace the printer's self-reported LAN IP in MQTT push_status with the
# IP you used to connect.  Enable this when you access the printer through
# NAT / port forwarding: without it, the slicer sees the printer's
# internal address (e.g. 192.168.1.100) and fails to open the camera
# or file browser from outside the LAN.
#
# Example NAT setup:
#   1. Forward ports 8883, 990, 6000 and 322 on your router to the printer.
#   2. In the slicer, connect using your public IP (or DDNS hostname).
#   3. Set override_lan_ip = 1 here so the camera and file browser also
#      use the public IP instead of the printer's internal address.

override_lan_ip = 0

# Patch incoming MQTT push_status fields on the fly. All disabled by
# default. Enable only if your printer needs it.
#
# Rewrite home_flag SD-card bits from NO_SDCARD (0) to HAS_SDCARD (1).
# Useful on some A-series (and similar) where Studio greys out "Send to
# Printer" / "Print via LAN" and shows a red storage tile even though
# USB storage works over FTPS. Many printers (e.g. P2S) do not need this.

patch_mqtt_home_flag = 0

# Inject ipcam.file block into push_status when the firmware omits it.
# Without this, Studio shows "Browsing file in storage is not supported"
# or "not supported in lan mode" and refuses to open the file browser.
# The file browser actually works (at least on A1), the printer
# just does not advertise the capability in its MQTT status. Only
# affects printers that do not report ipcam.file natively (e.g. X1/P1S
# already advertise it and are not affected).

patch_mqtt_ipcam_file = 0

# Set fun2 bit 17 (is_support_model_internal_storage) so Studio shows
# the internal storage (eMMC) tab in the file browser. Without this,
# only external storage (USB) is shown. Firmware often omits this bit
# even when :6000/FTPS lists emmc; browsing internal memory may still
# be slow or unreliable (e.g. on P2S) — enable only if you need the tab.

patch_mqtt_internal_storage = 0


# --- Cloud ----------------------------------------------------------
#
# Everything below talks to Bambu Lab's online services (login, status,
# print history, and sending a print through the cloud). Change these
# only if you understand the trade-offs for privacy and reliability.
#
# !!! WARNING !!!
#
# Full cloud operation with a secured printer also REQUIRES you to
# supply your own slicer_cert_id, slicer_key_pem, slicer_cert_pem, and
# slicer_crl_pem (see below). These are private credentials; this
# project does not distribute them. You must obtain them yourself, and
# you alone are responsible for ensuring that your use of them complies
# with applicable terms and law.

# Fully blocks talking to Bambu's cloud (live status, subscriptions,
# cloud printing / uploading print files), except login, syncing
# presets, and binding/unbinding a printer, which still work.
# If you want cloud printing or any of the cloud_print modes below,
# set this to 0 first.

block_cloud = 1

# Slicer certificate ID registered on the Bambu backend.
# If empty, reads slicer_cert_id.txt from this config directory.

slicer_cert_id =

# Path to the slicer RSA private key (PEM) used for MQTT payload signing
# and cloud REST request authentication.
# If empty, looks for slicer_key.pem in this config directory.

slicer_key_pem =

# Path to the app certificate chain (PEM) sent to the printer via the
# security.app_cert_install MQTT command (new authorization-control system).
# If empty, looks for slicer_cert.pem in this config directory.

slicer_cert_pem =

# Path to the app certificate revocation list (PEM CRL) sent alongside the
# app certificate in security.app_cert_install.
# If empty, looks for slicer_crl.pem in this config directory.

slicer_crl_pem =

# Name this plugin sends as the client identity on cloud API calls.
# Starting a cloud print / print history record is only accepted by
# Bambu when this matches the official slicer name "BambuStudio".
# The honest default below will be rejected for those print APIs until
# you change it.

client_name = OpenBambooNetworking

# How a print is sent when the slicer wants to use the cloud / "print
# with record" path (typical for a printer that is linked to your
# Bambu account). This does not change pure LAN-only printers.
#
#   cloud_only     — Default. The slicer first tries to put the model on
#                    the printer over your local network (LAN). If that
#                    fails, the full model is uploaded to the cloud instead.
#                    Either way the cloud is required for print history /
#                    reporting and to start the job — without a working
#                    cloud connection, printing will not work.
#
#   try_lan_first  — Prefer a fully private local send (same as when the
#                    printer is in LAN-only mode): put the file on the
#                    printer over your home/LAN network and start the print
#                    there, without uploading the full model to Bambu. If
#                    that fails (printer offline on LAN, wrong access code,
#                    upload error, …), the slicer is allowed to fall back
#                    to a normal cloud print (full model uploaded to Bambu).
#
#   lan_only       — Fully analogous to the printer being in LAN-only mode:
#                    always send and start the print locally. Never fall
#                    back to uploading the full model to the cloud. If the
#                    local send fails, the print simply fails.

cloud_print = cloud_only

# Hide cloud print history on the Bambu Studio home page (return an
# empty task list). Useful with true LAN print modes (try_lan_first /
# lan_only above), which do not write a cloud history entry — otherwise
# the home page still shows older cloud jobs and looks inconsistent.

cloud_hide_history = 0

# Server addresses (Global region — used when country is not China).

cloud_global_api_host = https://api.bambulab.com
cloud_global_web_host = https://bambulab.com
cloud_global_mqtt_host = us.mqtt.bambulab.com

# Server addresses (China region).

cloud_cn_api_host = https://api.bambulab.cn
cloud_cn_web_host = https://bambulab.cn
cloud_cn_mqtt_host = cn.mqtt.bambulab.com

cloud_mqtt_port = 8883
